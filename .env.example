# PostgreSQL (Railway: Variables → DATABASE_URL из плагина Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Обязательно в production (случайная длинная строка)
JWT_SECRET=

# Первый администратор: после первого запуска создаётся запись в таблице users (bcrypt).
# Дальше вход только по этой паре или по пользователям из БД.
ADMIN_PHONE=+998991234567
ADMIN_PASSWORD=
# Опционально: отображаемое имя первого админа
# ADMIN_DISPLAY_NAME=Администратор

# Telegram (опционально)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# Публичный HTTPS-URL приложения (если не определяется из запроса), например https://xxx.up.railway.app
# PUBLIC_APP_URL=

# Постоянное хранение медиа (Cloudinary) — чтобы фото не пропадали при деплоях
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

PORT=3000
# NODE_ENV=production
